{
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "preset": "conventionalcommits"
    }
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "npm": { "publish": false },
  "hooks": {
    "after:bump": "node -e \"const fs=require('fs'); const p=JSON.parse(fs.readFileSync('projects/fsociety/package.json','utf8')); p.version='${version}'; fs.writeFileSync('projects/fsociety/package.json', JSON.stringify(p,null,2)+'\\n');\""
  }
}
