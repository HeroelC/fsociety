{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/fsociety",
  "lib": {
    "entryFile": "src/public-api.ts",
    "styleIncludePaths": ["src/styles"]
  },
  "assets": [
    {
      "input": "src/styles",
      "glob": "_tokens.scss",
      "output": "/"
    },
    {
      "input": "src/styles",
      "glob": "_mixins.scss",
      "output": "/"
    },
    {
      "input": "src/styles",
      "glob": "_index.scss",
      "output": "/"
    },
    {
      "input": "src/styles",
      "glob": "global.scss",
      "output": "/"
    }
  ]
}
