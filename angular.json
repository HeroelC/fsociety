{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "fsociety": {
      "projectType": "library",
      "root": "projects/fsociety",
      "sourceRoot": "projects/fsociety/src",
      "prefix": "fs",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/fsociety/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/fsociety/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/fsociety/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/fsociety/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "projects/fsociety/.storybook",
            "browserTarget": "fsociety:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/fsociety"],
            "port": 6006,
            "styles": ["projects/fsociety/src/styles/global.scss"]
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "projects/fsociety/.storybook",
            "browserTarget": "fsociety:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/fsociety"],
            "outputDir": "storybook-static",
            "styles": ["projects/fsociety/src/styles/global.scss"]
          }
        }
      }
    },
    "fsociety-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/fsociety-demo",
      "sourceRoot": "projects/fsociety-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/fsociety-demo",
            "index": "projects/fsociety-demo/src/index.html",
            "browser": "projects/fsociety-demo/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/fsociety-demo/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/fsociety-demo/public"
              }
            ],
            "styles": ["projects/fsociety-demo/src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "fsociety-demo:build:production"
            },
            "development": {
              "buildTarget": "fsociety-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "projects/fsociety-demo/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/fsociety-demo/public"
              }
            ],
            "styles": ["projects/fsociety-demo/src/styles.scss"],
            "scripts": []
          }
        }
      }
    }
  }
}
